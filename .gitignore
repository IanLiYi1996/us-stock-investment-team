# .gitignore
# 敏感信息 — 不要 commit！
.env
*.env
credentials
.alpaca/
config/*.env
!config/*.example.env

# Python
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
env/

# 本地日志和数据
logs/
*.log
data/
memory/

# JSON：只忽略运行时数据，不忽略配置模板
signals/*.json
!openclaw/openclaw.example.json
!openclaw/cron/cron.example.json
!config/*.example.yaml

# macOS
.DS_Store

# IDE
.vscode/
.idea/
*.swp
