# Alpaca Paper Trading 密钥配置
# 复制为 .env 并填写真实密钥（不要 commit 到 Git！）

# Alpaca 模拟盘 API Key
# 注册地址：https://app.alpaca.markets/signup
ALPACA_API_KEY=YOUR_API_KEY_HERE
ALPACA_SECRET_KEY=YOUR_SECRET_KEY_HERE
ALPACA_PAPER=true

# Tavily 搜索 API（用于新闻调研）
# 注册地址：https://app.tavily.com
TAVILY_API_KEY=YOUR_TAVILY_API_KEY_HERE

# 可选：Finance Advisory API
ADVISOR_USERNAME=your@email.com
ADVISOR_PASSWORD=your_password_here
ADVISOR_AUTH_DOMAIN=your_cognito_auth_domain
